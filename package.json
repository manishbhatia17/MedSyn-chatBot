{
  "name": "chat-bot",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=127.0.0.1",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "bundle": "ng build --output-hashing none && node ./concat.js",
    "prodbundle": "ng build --configuration production --output-hashing none && node ./concat.js"
  },
  "private": true,
  "dependencies": {
