
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Productivity Summary";
}

@section Scripts {
    <script type="text/javascript" src="~/js/App/Controllers/Reports/productivityReportController.js"></script>
    <script type="text/javascript" src="~/js/App/Services/archivedInvoiceService.js"></script>
}
<div ng-controller="productivityReportController" ng-init="init(@Model)" ng-cloak>
    <div class="row">
        <div class="col-md-12">
            <h2>Productivity Summary</h2>
        </div>
    </div>
    <div class="row">
            <div class="col-md-12">
                <select>
                    <option>30 Days</option>
                </select>
            </div>
    </div>
    <div class="row">
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-header">
                    <h3>Total Invoices</h3>
                </div>
                <div class="panel-body">
                    <h4>100</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-header">
                    <h3>Total Invoices Billed</h3>
                </div>
                <div class="panel-body">
                    <h4>$1600</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-header">
                    <h3>Total Items Packed</h3>
                </div>
                <div class="panel-body">
                    <h4>430</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="panel panel-default">
                <div class="panel-header">
                    <h3>Total Orders Packed</h3>
                </div>
                <div class="panel-body">
                    <h4>100</h4>
                </div>
            </div> 
        </div>
    </div>
    <div class="row">
        <div class="col-md-6">
            <b>Invoices Packed by Packer</b>
            <canvas id="packingChart"></canvas>
        </div>
        <div class="col-md-6">
            <b>Invoices Shipped by Shipper</b>
            <canvas id="shippingChart"></canvas>
        </div>
    </div>
</div>
<div class="row">
    <div class="table">
        <table class="table table-striped">
            <tr>
                <th></th>
                <th>Name</th>
                <th>Total Items Packed</th>
                <th>Total Items Shipped</th>
            </tr>
            <tbody>
                <tr>
                    <td>+</td>
                    <td>Packer 1</td>
                    <td>12</td>
                    <td>0</td>
                </tr>
                <tr>
                    <td>-</td>
                    <td>Packer 2</td>
                    <td>19</td>
                    <td>0</td><
                </tr>
                <tr>
                    <td></td>
                <td></td>
                <td colspan="2">
                    <table class="table">
                        <tr><td>Date</td><td>Total Items Packed</td><td>Total Items Shipped</td></tr>
                        <tr>
                            <td>1/1/2024</td>
                            <td>2</td>
                            <td>0</td>
                        </tr>
                            <tr>
                                <td>1/2/2024</td>
                                <td>7</td>
                                <td>0</td>
                            </tr>
                            <tr>
                                <td>1/3/2024</td>
                                <td>2</td>
                                <td>0</td>
                            </tr>
                    </table>
                </td>
            </tr>
                <tr>
                    <td>+</td>
                    <td>Packer 3</td>
                    <td>3</td>
                    <td>0</td>
                </tr>
                <tr>
                    <td>+</td>
                    <td>Packer 4</td>
                    <td>15</td>
                    <td>0</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div>
    <canvas id="myChart"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
   


</script>
