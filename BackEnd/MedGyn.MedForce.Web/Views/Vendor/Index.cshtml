
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewData["Title"] = "Vendors";
}

@section Scripts {
	<script type="text/javascript" src="~/js/App/Controllers/vendorListController.js"></script>
	<script type="text/javascript" src="~/js/App/Services/vendorService.js"></script>
}

<div ng-controller="vendorListController" ng-cloak>
	<h1>
		Vendor List
	</h1>
	<div class="body-wrapper">
		<list-table
			table="table"
			service="vendorService"
			fetch-func="fetchVendors"
			details-route="/vendor/details/"
		></list-table>
	</div>
</div>

