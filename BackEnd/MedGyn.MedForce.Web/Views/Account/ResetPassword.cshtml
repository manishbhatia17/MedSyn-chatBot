@model MedGyn.MedForce.Facade.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<h2>Reset Password</h2>

@using (Html.BeginForm("ResetPassword", "Account", null, FormMethod.Post, null, new { @class = "form-horizontal form-material", role = "form" }))
{
    <div class="form-group">
        <div class="col-xs-12">
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "text", autocomplete = "off", placeholder = "Email", aria_required = "true", aria_describedby = "email-error" })
        </div>
    </div>
    <div class="form-group text-center m-t-20">
        <div class="col-xs-12">
            <button type="submit" class="btn btn-primary btn-lg btn-block text-uppercase">Send Email</button>
        </div>
    </div>

    <div class="form-group m-b-0">
        <p>Please note: Email address provided will be validated.  An email with instructions to reset the password will be sent to valid email addresses.</p>
    </div>
    
    <br/>

    <div class="form-group m-b-0">
        <div class="col-xs-12 text-center">
            <span>Already have your password?</span> @Html.ActionLink("Login", "Login", "Account")
        </div>
    </div>
}
