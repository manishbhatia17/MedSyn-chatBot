@model MedGyn.MedForce.Facade.ViewModels.LoginViewModel
@{
	ViewData["Title"] = "Login";
	Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<h2>SIGN IN</h2>

@using (Html.BeginForm("Login", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post, null, new { @class = "form-horizontal form-material", id = "loginForm" }))
{
	@if (Model != null && !Model.Success)
	{
		<div class="alert alert-danger">
			@foreach (var error in Model.Errors)
			{
				<div>@error</div>
			}
		</div>
	}
    
	    <div class="form-group">
		    <div class="col-xs-12">
			    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "text", autocomplete = "email", placeholder = "Email", aria_required = "true", aria_describedby = "email-error" })
		    </div>
	    </div>
	    <div class="form-group">
		    <div class="col-xs-12">
			    @Html.PasswordFor(m => m.Password, new { @class = "form-control", autocomplete = "current-password", placeholder = "Password", aria_required = "true", aria_describedby = "password-error" })
		    </div>
	    </div>
    <div class="form-group text-center">
        <div class="row">
            <div class="col-sm-6">
                <div class="checkbox checkbox-success" class="pull-left">
                    @Html.CheckBoxFor(expression: model => model.RememberMe, new {@class = "form-control", @id = "cbRememberMe", type = "checkbox", autocomplete = "", placeholder = "", aria_required = "true", aria_describedby = ""})
                    <label for="cbRememberMe">Remember Me</label>
                </div>
            </div>
            <div class="col-sm-6">
                <div>
                    <a href="@Url.Action("ResetPassword")" id="to-recover"><i class="fa fa-lock m-r-5"></i> Forgot password?</a>
                </div>
            </div>
        </div>

    </div>
        <div class="form-group text-center m-t-20">
            <div class="col-xs-12">
                <button type="submit" class="btn btn-primary btn-lg btn-block text-uppercase" style="background-color: #919d9d; color: white" onclick="sessionStorage.clear()">LOG IN</button>
            </div>
        </div>
    
}

