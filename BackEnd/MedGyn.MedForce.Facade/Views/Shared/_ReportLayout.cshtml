<!DOCTYPE html>

<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />

	<style>
		html {
			height: 100%
		}
		body {
			margin: 0;
			font-family: sans-serif;
			width: 100%;
			height: 100%;
			font-size: 16px;
			position: relative;
		}
		body > div {
			margin-bottom: 20px;
		}
		.flex > div {
			display: inline-block;
			vertical-align: top;
		}
		.box {
			width: 30%;
			height: 1px; /* hack to make height work */
		}
		.box > div {
			border: 2px solid #BBBBBB;
			padding: 10px;
			vertical-align: top;
			height: 100%;
			margin-right: 10px;
		}
		.box table td:first-child {
			white-space: nowrap;
			padding-right: 10px;
			vertical-align: top;
		}
		.box:last-child > div {
			margin-right: 0;
		}

		.half-children {
			width: 100%;
			vertical-align: top;
		}
		.half-children > * {
			width: 49%;
			display: inline-block;
			vertical-align: top;
		}
		table {
			width: 100%;
			border-spacing: 0;
		}
		.stripe tbody tr:nth-child(odd) {
			background-color: #f4f8fb;
		}
		.stripe th {
			text-align: left;
			border-bottom: 1px solid #111;
			padding: 0 5px;
		}
		.stripe td {
			padding: 0 5px;
		}
		.footer {
			margin-top: 100px;
			bottom: 0;
			font-size: 12px;
			text-align: center;
		}
		.medgyn-info {
			margin-bottom: 40px;
		}
		.align-right {
			text-align: right !important;
		}
		.side-label {
			width: 70px;
		}
		.address-label {
			width: 80%;
		}
	</style>
</head>

<body class="report">
	@RenderBody()
</body>
</html>
